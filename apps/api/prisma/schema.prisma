// ====================================================================================
// 1. DATABASE CONNECTION BLOCK
// ====================================================================================

datasource db {

  provider = "postgresql"        // database management system being used (e.g., postgresql, mysql, sqlite, mongodb)
  url      = env("DATABASE_URL") // database's secure password waala connection path being pulled from env
}

// ====================================================================================
// 2. PRISMA CLIENT GENERATOR BLOCK
// ====================================================================================

generator client {
  provider = "prisma-client-js" // Prisma ORM should generate types and methods for JavaScript/TypeScript
}

